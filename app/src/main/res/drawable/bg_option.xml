<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com">
    <!-- Quando o botão está selecionado (clicado) -->
    <item android:state_checked="true">
        <shape>
            <solid android:color="#33EBBD2D" /> <!-- Amarelo suave no fundo -->
            <stroke android:width="2dp" android:color="#ebbd2d" /> <!-- Borda amarela forte -->
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Quando NÃO está selecionado (estado padrão) -->
    <item>
        <shape>
            <solid android:color="#1A1A1A" /> <!-- Fundo escuro -->
            <stroke android:width="1dp" android:color="#333333" /> <!-- Borda cinza discreta -->
            <corners android:radius="12dp" />
        </shape>
    </item>
</selector>
